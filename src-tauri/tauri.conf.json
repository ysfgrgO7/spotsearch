{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spotsearch",
  "version": "1.0.3",
  "identifier": "com.ysf.spotsearch",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpotSearch",
        "width": 660,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "SpotSearch Launcher",
      "args": [
        {
          "name": "toggle",
          "short": "t",
          "description": "Toggles the visibility of the search window"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
